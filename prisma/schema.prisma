// Prisma schema — Postgres (Neon) for production; set DATABASE_URL in .env / .env.local
// or in your hosting provider's environment variables.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  passwordHash String
  fullName  String?
  phone     String?
  address   String?
  startupName String?
  industries String?   // JSON array of industry strings
  stage     String?    // Initial idea / Pre-seed / Market-ready / Growth
  role      String   @default("FOUNDER") // FOUNDER | ADMIN | SUPERADMIN
  lastSeenAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions     Session[]
  answers      Answer[]
  assessments  IrlAssessment[]
  modules      ModuleProgress[]
  chatLogs     ChatLog[]
  adminActions AdminLog[] @relation("AdminActor")
  uploads      KnowledgeDocument[] @relation("DocUploader")
  resetTokens  PasswordResetToken[]

  @@index([role])
}

// Single-use, time-limited password reset tokens.
// We store the SHA-256 hash of the token, not the token itself — the plaintext
// only ever exists in the user's email link and the browser URL bar.
model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique  // sha256 hex of the raw token
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

// Audit log of admin actions — populated by anything calling logAdminAction()
model AdminLog {
  id           String   @id @default(cuid())
  adminId      String
  admin        User     @relation("AdminActor", fields: [adminId], references: [id], onDelete: Cascade)
  action       String   // "user.view" | "user.impersonate" | "doc.upload" | "doc.delete" | "rubric.update" | "export.csv" | "admin.promote" | ...
  resourceType String?  // "user" | "document" | "rubric" | "chat"
  resourceId   String?
  metadata     String?  // JSON blob with extra context (search query, filters, etc.)
  createdAt    DateTime @default(now())

  @@index([adminId])
  @@index([createdAt])
  @@index([resourceType, resourceId])
}

// Admin-uploaded knowledge sources powering AskMe RAG.
// One document = one source file; many chunks per document.
model KnowledgeDocument {
  id          String   @id @default(cuid())
  title       String
  source      String   // human-readable source label, e.g. "Italian Startup Act §4"
  filename    String?
  mimeType    String?
  sizeBytes   Int?
  uploadedById String?
  uploadedBy  User?    @relation("DocUploader", fields: [uploadedById], references: [id], onDelete: SetNull)
  status      String   @default("active") // active | archived
  tags        String?  // JSON array of tags
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  chunks      KnowledgeChunk[]

  @@index([status])
}

// Indexed chunk for retrieval. Postgres full-text search on `text`.
model KnowledgeChunk {
  id         String   @id @default(cuid())
  documentId String
  document   KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  ordinal    Int      // chunk position within document, for ordering
  text       String
  tokens     Int?     // approximate token count
  createdAt  DateTime @default(now())

  @@index([documentId])
}

// Log of every AskMe turn for admin review and prompt/RAG improvement.
// Anonymous turns (logged-out users) have userId = null.
model ChatLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  locale     String?  // "en" | "it"
  userMessage String  // last user turn
  assistantMessage String // full assistant reply
  ragSources String?  // JSON array of retrieved chunk ids / source labels
  flagged    Boolean  @default(false)
  flagReason String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@index([flagged])
}

// Admin-editable overrides for the IRL scoring rubric.
// One row per section + version. Most recent active version per section is used.
model RubricOverride {
  id        String   @id @default(cuid())
  section   String   // "irl-1" .. "irl-9"
  version   String   // e.g. "2026-05-v2"
  active    Boolean  @default(true)
  rubricJson String  // full rubric override (criteria + weights + gap tags)
  notes     String?
  createdById String?
  createdAt DateTime @default(now())

  @@index([section, active])
}

model Session {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentStep String   @default("personal")  // "personal" | "irl-1" ... "irl-9" | "review" | "submitted"
  submitted  Boolean   @default(false)
  submittedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

// One row per (user, questionId). Upserted on every change so resume works.
model Answer {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  questionId String   // e.g. "q8", "q21"
  // Stored as JSON string — may be scalar, array (multi-select), or text
  value      String
  updatedAt  DateTime @updatedAt

  @@unique([userId, questionId])
  @@index([userId])
}

// Per-section IRL readiness score, computed by Claude after a section is completed.
// Re-computed (new row) when the user re-takes the section after a learning module.
model IrlAssessment {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  section   String   // "irl-1" .. "irl-9"
  score     Int      // 0..100
  diagnosis String   // 1-sentence summary
  strengths String   // JSON array of strings
  gaps      String   // JSON array of strings
  gapTags   String   // JSON array of controlled-vocabulary tags driving recommendations
  rubricVer String   // version of the rubric the score was computed against
  createdAt DateTime @default(now())

  @@index([userId, section])
}

// Tracks the founder's progress through learning modules.
// One row per (user, moduleId). status transitions: suggested -> started -> completed/skipped
model ModuleProgress {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  moduleId    String    // e.g. "m14-bmc"
  status      String    @default("suggested") // suggested | started | completed | skipped
  beatIndex   Int       @default(0)            // current beat within the module
  outputs     String?                         // JSON: structured submissions (BMC blocks, etc.)
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([userId, moduleId])
  @@index([userId])
}

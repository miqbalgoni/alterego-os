# Copy to .env.local and fill in values

# SQLite for offline/local testing. Switch to Postgres URL for production.
DATABASE_URL="file:./dev.db"

# Anthropic API key — required for "Ask Me" chat widget and orchestrator agent.
# Ask Me will gracefully degrade with a placeholder message if missing.
ANTHROPIC_API_KEY=""

# Model IDs (can be overridden)
ANTHROPIC_MODEL_ORCHESTRATOR="claude-sonnet-4-5"
ANTHROPIC_MODEL_ASKME="claude-sonnet-4-5"
